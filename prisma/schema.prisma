generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid()) @map("_id")
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  country       String?
  totalXp       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  placementTests       PlacementTest[]
  roadmaps             Roadmap[]
  lessonProgress       LessonProgress[]
  streaks              Streak[]
  userAchievements     UserAchievement[]
  friendsInitiated     Friendship[]       @relation("FriendInitiator")
  friendsReceived      Friendship[]       @relation("FriendReceiver")
  studyGroupMembers         StudyGroupMember[]
  studyGroupMessages        StudyGroupMessage[]
  studyGroupInvitesSent     StudyGroupInvite[] @relation("InviteSent")
  studyGroupInvitesReceived StudyGroupInvite[] @relation("InviteReceived")
  streakGiftsSent      StreakGift[]       @relation("GiftSender")
  streakGiftsReceived  StreakGift[]       @relation("GiftReceiver")
  notifications        Notification[]
  quizParticipants     QuizParticipant[]
  quizAnswers          QuizAnswer[]
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Placement Test ──────────────────────────────────────────────────────────

model PlacementTest {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  language    String
  testType    String   @default("cefr")
  level       String
  score       Int
  answers     String
  completedAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap Roadmap?
}

// ─── Roadmap ─────────────────────────────────────────────────────────────────

model Roadmap {
  id              String    @id @default(cuid()) @map("_id")
  userId          String
  language        String
  targetExam      String?
  targetScore     Int?
  currentLevel    String
  targetLevel     String
  startDate       DateTime  @default(now())
  targetDate      DateTime
  weeklyHours     Int       @default(7)
  busyDays        Int[]     @default([])
  status          String    @default("active")
  totalWeeks      Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  learningFocus   String    @default("comprehensive")

  placementTestId String        @unique
  placementTest   PlacementTest @relation(fields: [placementTestId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks           RoadmapWeek[]
}

model RoadmapWeek {
  id         String   @id @default(cuid()) @map("_id")
  roadmapId  String
  weekNumber Int
  theme      String
  skills     String
  status     String   @default("pending")
  startDate  DateTime

  roadmap Roadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  days    RoadmapDay[]
}

model RoadmapDay {
  id            String    @id @default(cuid()) @map("_id")
  weekId        String
  dayNumber     Int
  lessonType    String
  lessonId      String?
  scheduledDate DateTime?
  status        String    @default("pending")
  completedAt   DateTime?

  week   RoadmapWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  lesson Lesson?     @relation(fields: [lessonId], references: [id])
}

// ─── Lessons ─────────────────────────────────────────────────────────────────

model Lesson {
  id          String   @id @map("_id")
  language    String
  type        String
  level       String
  title       String
  description String?
  content     String
  duration    Int      @default(15)
  xpReward    Int      @default(10)
  createdAt   DateTime @default(now())

  roadmapDays    RoadmapDay[]
  lessonProgress LessonProgress[]
}

model LessonProgress {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  lessonId    String
  score       Int?
  timeSpent   Int?
  attempts    Int      @default(1)
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ─── Streaks ─────────────────────────────────────────────────────────────────

model Streak {
  id               String    @id @default(cuid()) @map("_id")
  userId           String
  language         String
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  frozenUntil      DateTime?
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
}

model StreakGift {
  id         String   @id @default(cuid()) @map("_id")
  senderId   String
  receiverId String
  language   String
  message    String?
  sentAt     DateTime @default(now())

  sender   User @relation("GiftSender",   fields: [senderId],   references: [id])
  receiver User @relation("GiftReceiver", fields: [receiverId], references: [id])
}

// ─── Achievements ────────────────────────────────────────────────────────────

model Achievement {
  id          String @id @default(cuid()) @map("_id")
  code        String @unique
  name        String
  description String
  icon        String
  category    String
  xpReward    Int    @default(50)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid()) @map("_id")
  userId        String
  achievementId String
  language      String?
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Friendship {
  id          String   @id @default(cuid()) @map("_id")
  initiatorId String
  receiverId  String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  initiator User @relation("FriendInitiator", fields: [initiatorId], references: [id])
  receiver  User @relation("FriendReceiver",  fields: [receiverId],  references: [id])

  @@unique([initiatorId, receiverId])
}

model StudyGroup {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  description String?
  language    String
  maxMembers  Int      @default(10)
  createdById String
  createdAt   DateTime @default(now())

  members      StudyGroupMember[]
  messages     StudyGroupMessage[]
  invites      StudyGroupInvite[]
  quizSessions QuizSession[]
}

model StudyGroupMember {
  id       String   @id @default(cuid()) @map("_id")
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model StudyGroupMessage {
  id        String   @id @default(cuid()) @map("_id")
  groupId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyGroupInvite {
  id        String   @id @default(cuid()) @map("_id")
  groupId   String
  inviterId String
  inviteeId String
  // pending_admin | pending_invitee | accepted | rejected
  status    String   @default("pending_admin")
  createdAt DateTime @default(now())

  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User       @relation("InviteSent",     fields: [inviterId], references: [id])
  invitee User       @relation("InviteReceived", fields: [inviteeId], references: [id])
}

model Notification {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Review / Ôn tập ─────────────────────────────────────────────────────────

model ReviewSet {
  id          String   @id @default(cuid()) @map("_id")
  language    String   // english | thai
  // vocabulary | grammar | quiz_15 | quiz_30 | simulation_b1 | simulation_toeic
  type        String
  topic       String   // e.g. "travel", "past_simple", "random_vocab"
  level       String   // A1 | A2 | B1 | B2 | C1
  title       String
  description String?
  duration    Int      // phút (15 hoặc 30)
  createdAt   DateTime @default(now())

  questions    ReviewQuestion[]
  quizSessions QuizSession[]
}

model ReviewQuestion {
  id          String   @id @default(cuid()) @map("_id")
  reviewSetId String
  order       Int
  question    String
  options     String[] // 4 lựa chọn
  answer      Int      // index đáp án đúng (0-3)
  explanation String?

  reviewSet ReviewSet @relation(fields: [reviewSetId], references: [id], onDelete: Cascade)
}

// ─── Group Quiz ───────────────────────────────────────────────────────────────

model QuizSession {
  id              String    @id @default(cuid()) @map("_id")
  groupId         String
  reviewSetId     String
  createdById     String
  // waiting | active | finished
  status          String    @default("waiting")
  currentQuestion Int       @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())

  group        StudyGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reviewSet    ReviewSet         @relation(fields: [reviewSetId], references: [id])
  participants QuizParticipant[]
  answers      QuizAnswer[]
}

model QuizParticipant {
  id        String   @id @default(cuid()) @map("_id")
  sessionId String
  userId    String
  score     Int      @default(0)
  joinedAt  DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
}

model QuizAnswer {
  id            String   @id @default(cuid()) @map("_id")
  sessionId     String
  userId        String
  questionIndex Int
  answer        Int      // index đáp án user chọn
  isCorrect     Boolean
  answeredAt    DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId, questionIndex])
}
